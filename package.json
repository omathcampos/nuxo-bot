{
  "name": "nuxo-bot",
  "version": "1.0.0",
  "description": "Bot de assessoria financeira pessoal via Telegram",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@grammyjs/conversations": "^2.0.0",
    "@supabase/supabase-js": "^2.46.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "grammy": "^1.34.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
